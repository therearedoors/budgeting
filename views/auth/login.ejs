<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<main class="container auth-container">
  <section class="card auth-card">
    <h1>Login</h1>
    <p class="subtitle">Track your incomings and outgoings in pounds sterling.</p>

    <% if (errors && errors.length) { %>
      <div class="alert alert-error">
        <ul>
          <% errors.forEach(function(err) { %>
            <li><%= err.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/login" class="form">
      <label>
        Email
        <input type="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required autofocus>
      </label>
      <label>
        Password
        <input type="password" name="password" required>
      </label>
      <button type="submit" class="btn btn-primary">Login</button>
    </form>

    <p class="auth-switch">No account? <a href="/register">Register</a></p>
  </section>
</main>

<%- include('../partials/footer') %>